---
import Layout from './Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';

interface Props {
  frontmatter: {
    metaTitle?: string;
    pageTitle?: string;
    lastUpdated?: string;
  };
}

const { frontmatter } = Astro.props as Props;
const metaTitle = frontmatter.metaTitle ?? 'Symptoria';
const pageTitle = frontmatter.pageTitle;
const lastUpdated = frontmatter.lastUpdated;
---

<Layout title={metaTitle}>
  <Navbar client:load />

  <main class="px-6 pb-20 pt-36 md:pt-40">
    <div class="mx-auto max-w-3xl rounded-3xl border border-border bg-surface/80 p-8 shadow-overlay backdrop-blur-sm md:p-12">
      {(pageTitle || lastUpdated) && (
        <header class="mb-8 border-b border-border/80 pb-6 text-center">
          {pageTitle && (
            <h1 class="font-sans text-[clamp(2.25rem,5vw,3.5rem)] font-bold leading-[0.95] tracking-[-0.05em] text-balance text-foreground">
              {pageTitle}
            </h1>
          )}
          {lastUpdated && (
            <p class="mt-4 font-mono text-[0.78rem] uppercase tracking-[0.08em] text-foreground/52">
              Last updated: {lastUpdated}
            </p>
          )}
        </header>
      )}

      <article class="text-foreground/88 leading-7 [&>*:first-child]:mt-0 [&_a]:text-link [&_a]:underline [&_a]:underline-offset-[0.18em] [&_h1]:font-sans [&_h1]:text-[clamp(1.9rem,4vw,2.75rem)] [&_h1]:font-bold [&_h1]:leading-none [&_h1]:tracking-[-0.05em] [&_h1]:text-foreground [&_h2]:mt-10 [&_h2]:font-sans [&_h2]:text-lg [&_h2]:font-[650] [&_h2]:tracking-[-0.03em] [&_h2]:text-foreground [&_p]:mt-4 [&_strong]:text-foreground [&_ul]:mt-4 [&_ul]:list-disc [&_ul]:pl-5">
        <slot />
      </article>
    </div>
  </main>

  <Footer />
</Layout>

---
import Layout from '../layouts/Layout.astro';
import V2_Navbar from '../components/v2/Navbar';
import V2_Hero from '../components/v2/Hero';
import V2_FeatureList from '../components/v2/FeatureList';
import V2_Waitlist from '../components/v2/Waitlist';
import Footer from '../components/Footer';
import VersionSwitcher from '../components/VersionSwitcher';
---

<Layout title="Symptoria | V2: Swiss Brutalist">
	<V2_Navbar client:load />
	<main class="bg-[#f2f2f2]">
		<V2_Hero client:load />
		
		{/* Manifesto Section */}
		<section class="py-24 bg-black text-white">
			<div class="container mx-auto px-6">
				<div class="max-w-4xl">
					<div class="font-mono text-xs uppercase tracking-widest mb-8 text-accent">[Manifesto.txt]</div>
					<h2 class="text-4xl md:text-6xl font-sans font-black uppercase tracking-tighter leading-none mb-12">
						We believe health data belongs to the individual, not the corporation.
					</h2>
					<p class="font-mono text-xl leading-relaxed opacity-60">
						SYMPTORIA IS AN ARCHITECTURE OF CLARITY. <br />
						NO CLOUD. NO TRACKING. NO COMPROMISE. <br />
						JUST YOUR HISTORY, SECURED LOCALLY.
					</p>
				</div>
			</div>
		</section>

		<V2_FeatureList client:load />
		<V2_Waitlist client:load />
	</main>
	<Footer />
	<VersionSwitcher client:load />
</Layout>

<style is:global>
	@import url('https://fonts.googleapis.com/css2?family=Geist+Mono:wght@100..900&display=swap');
	
	:root {
		--font-mono: 'Geist Mono', monospace;
	}
</style>

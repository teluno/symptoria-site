---
import Layout from '../layouts/Layout.astro';
import V4_Navbar from '../components/v4/Navbar';
import V4_Hero from '../components/v4/Hero';
import V4_Bento from '../components/v4/Bento';
import V4_Waitlist from '../components/v4/Waitlist';
import Footer from '../components/Footer';
import VersionSwitcher from '../components/VersionSwitcher';
---

<Layout title="Symptoria | V4: Tactical Dark">
	<V4_Navbar client:load />
	<main class="bg-[#050505]">
		<V4_Hero client:load />
		
		{/* Data Security Visualization */}
		<section id="security" class="py-32 border-y border-white/5 bg-[#080808]">
			<div class="container mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
				<div class="animate-fade-up">
					<div class="font-mono text-blue-500 text-xs uppercase tracking-[0.3em] mb-8">Node Architecture</div>
					<h2 class="text-4xl md:text-6xl font-sans font-black uppercase tracking-tighter leading-[0.9] text-white mb-10">
						Decentralized <br />
						By Architecture.
					</h2>
					<p class="text-xl text-white/40 font-mono leading-relaxed mb-12">
						Traditional health apps store your sensitive data on central servers. Symptoria reverses this. Your device is the only source of truth.
					</p>
					<div class="grid grid-cols-2 gap-8 font-mono">
						<div>
							<div class="text-blue-500 text-2xl font-black mb-2">0</div>
							<div class="text-[10px] text-white/40 uppercase tracking-widest leading-tight">Central <br /> Databases</div>
						</div>
						<div>
							<div class="text-blue-500 text-2xl font-black mb-2">256-bit</div>
							<div class="text-[10px] text-white/40 uppercase tracking-widest leading-tight">Local <br /> Encryption</div>
						</div>
					</div>
				</div>
				
				<div class="relative aspect-square border border-white/10 rounded-[4rem] p-12 flex items-center justify-center overflow-hidden">
					<div class="absolute inset-0 bg-[conic-gradient(from_0deg,transparent,rgba(0,100,255,0.1),transparent)] animate-[spin_10s_linear_infinite]" />
					<div class="w-full h-full bg-black/50 backdrop-blur-3xl rounded-[3rem] border border-white/10 flex items-center justify-center z-10">
						<svg width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5" class="text-blue-500/40">
							<rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
							<path d="M7 11V7a5 5 0 0 1 10 0v4" />
						</svg>
					</div>
				</div>
			</div>
		</section>

		<V4_Bento client:load />
		<V4_Waitlist client:load />
	</main>
	<Footer />
	<VersionSwitcher client:load />
</Layout>

<style is:global>
	:root {
		color-scheme: dark;
	}
</style>
